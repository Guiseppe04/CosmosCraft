# Server Configuration
NODE_ENV=development
PORT=5000

# Database
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/cosmoscraft

# JWT Configuration
JWT_SECRET=your-secret-key-change-this
JWT_EXPIRE=7d
REFRESH_TOKEN_EXPIRE=30d

# ===========================================
# FRONTEND URL - Automatically switches based on NODE_ENV
# ===========================================
# Development (default): http://localhost:3000
# Production: https://cosmoscraft.netlify.app
FRONTEND_URL=http://localhost:3000
FRONTEND_URL_PROD=https://cosmoscraft.netlify.app

# ===========================================
# OAuth - Google
# ===========================================
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
# Development callback
GOOGLE_CALLBACK_URL=http://localhost:5000/auth/google/callback
# Production callback
GOOGLE_CALLBACK_URL_PROD=https://your-production-server.com/auth/google/callback

# ===========================================
# OAuth - Facebook
# ===========================================
FACEBOOK_APP_ID=your-facebook-app-id
FACEBOOK_APP_SECRET=your-facebook-app-secret
# Development callback
FACEBOOK_CALLBACK_URL=http://localhost:5000/auth/facebook/callback
# Production callback
FACEBOOK_CALLBACK_URL_PROD=https://your-production-server.com/auth/facebook/callback

# ===========================================
# Email Service (Gmail)
# ===========================================
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=your-email@gmail.com
MAIL_PASS=your-app-password
MAIL_FROM=noreply@cosmoscraft.com

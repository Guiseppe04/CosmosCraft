# ===========================================
# Frontend Configuration - Automatically switches based on VITE_ENV
# ===========================================
# Development (default): http://localhost:5000
# Production: Set VITE_ENV=production and use deployed API

# Development API URL
VITE_API_URL=http://localhost:5000

# Production API URL (use when deploying)
VITE_API_URL_PROD=https://your-production-server.com

# App Name
VITE_APP_NAME=CosmosCraft
